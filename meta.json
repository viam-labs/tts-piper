{
  "module_id": "viam-labs:tts-piper",
  "visibility": "public",
  "url": "https://github.com/viam-labs/tts-piper",
  "description": "A modular service that provides text-to-speech (TTS) capabilities for machines running on the Viam platform.",
  "models": [
    {
      "api": "viam-labs:service:speech",
      "model": "viam-labs:speech:tts-piper",
      "markdown_link": "README.md#config",
      "short_description": "Provides text-to-speech(TTS) capabilities through a local model"
    }
  ],
  "entrypoint": "run.sh",
  "first_run": "setup.sh",
  "build": {
    "setup": "",
    "build": "./build.sh",
    "path": "module.tar.gz",
    "arch": [
      "linux/amd64",
      "linux/arm64",
      "darwin/arm64"
    ]
  }
}
